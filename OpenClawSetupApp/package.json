{
  "name": "OpenClawSetupApp",
  "version": "1.0.0",
  "description": "A macOS GUI app for OpenClaw setup, wrapping the shell script in a user-friendly interface.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "package-mac": "electron-packager . OpenClawSetupApp --platform=darwin --arch=universal --overwrite"
  },
  "dependencies": {
    "electron": "^28.2.3"
  },
  "devDependencies": {
    "electron-packager": "^17.1.1"
  }
}
